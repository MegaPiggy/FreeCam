{
  "$schema": "https://raw.githubusercontent.com/ow-mods/owml/master/schemas/config_schema.json",
  "enabled": true,
  "settings": {
    "Camera": {
      "type": "separator",
      "title": "Camera Settings"
    },
    "FOV": {
      "title": "FOV",
      "type": "slider",
      "min": 10,
      "max": 170,
      "value": 90,
      "tooltip": "Field of view in degrees. Higher values widen the view, lower values zoom in."
    },
    "Near Clip Plane Distance": {
      "title": "Near Clip Plane Distance",
      "type": "number",
      "value": 1,
      "tooltip": "Minimum distance away from camera at which objects are rendered."
    },
    "Prompts": {
      "type": "separator",
      "title": "Button Prompt Settings"
    },
    "Hide Prompts": {
      "title": "Hide Button Prompts",
      "type": "toggle",
      "value": false,
      "tooltip": "Hide all button prompts. (except toggle)"
    },
    "Hide Toggle Prompt": {
      "title": "Hide Toggle Prompt",
      "type": "toggle",
      "value": false,
      "tooltip": "Hide the toggle button prompt."
    }
  }
}